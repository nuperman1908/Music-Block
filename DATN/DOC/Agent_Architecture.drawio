<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram name="Kiến trúc Agent" id="agent-arch">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Sơ đồ kiến trúc Agent — quan hệ giữa BotControl, Movement, Rigidbody2D, DecisionRequester, Grid2DSensorComponent" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1460" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="go" value="GameObject &quot;Bot&quot;  (RequireComponent — gắn cùng một object)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;strokeWidth=2;dashed=1;fontStyle=1;fontSize=13;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1420" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="bot" value="BotControl : Agent&#10;────────────────&#10;Initialize()&#10;OnEpisodeBegin()&#10;CollectObservations(VectorSensor)&#10;OnActionReceived(ActionBuffers)&#10;Heuristic(ActionBuffers)&#10;HandleDeath() / HandleWin()&#10;&#10;Fields: spawnPoints, _movement, _rb,&#10;reward params (distance/jump/death/win)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="380" height="260" as="geometry"/>
        </mxCell>

        <mxCell id="mov" value="Movement : MonoBehaviour&#10;────────────────&#10;FixedUpdate(): chạy/nhảy theo gamemode&#10;Cube/Ship/Ball/UFO/Wave/Robot/Spider&#10;SetBotAction(int) / BotAction&#10;GetMouseButton*(): trả về theo isBot&#10;OnCollisionEnter2D → Die() / Win()&#10;ChangeThroughPortal(), ApplyOrbJump()&#10;&#10;Events:&#10;  event Action OnDied&#10;  event Action OnWon&#10;Fields: isBot, CurrentGamemode,&#10;CurrentSpeed, gravityDirection, yLastPortal" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="380" height="300" as="geometry"/>
        </mxCell>

        <mxCell id="rb" value="Rigidbody2D  (Unity)&#10;────────────────&#10;velocity, gravityScale, simulated&#10;&#10;Mô phỏng vật lý 2D theo gamemode" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="380" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="dec" value="DecisionRequester  (ML-Agents)&#10;────────────────&#10;DecisionPeriod (mỗi N bước Academy)&#10;TakeActionsBetweenDecisions&#10;&#10;Tự động gọi Agent.RequestDecision()&#10;theo nhịp cố định" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="460" width="380" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="grid" value="Grid2DSensorComponent : SensorComponent&#10;────────────────&#10;cellScale, gridSize (W×H), gridOffset&#10;detectableTags[], colliderMask&#10;CreateSensors() → ISensor[]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="120" width="380" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="grid_sensor" value="Grid2DSensor : ISensor&#10;────────────────&#10;ObservationSpec.Visual(H, W, channels)&#10;UpdateGrid(): Physics2D.OverlapBox mỗi ô,&#10;đối chiếu tag → bật kênh tương ứng&#10;Write(ObservationWriter) → quan sát hình ảnh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5e9ff;strokeColor=#9673a6;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="320" width="380" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="grid_world" value="Physics2D Scene  (Block / Spike / Portal ...)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="1040" y="520" width="380" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="brain" value="Neural Network Policy  (.onnx, ML-Agents)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1e1e;strokeColor=#666666;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="710" width="380" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="trainer" value="Trainer (Python — mlagents-learn)&#10;Chỉ hoạt động khi huấn luyện qua MLAgents communicator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3c3f41;strokeColor=#666666;fontColor=#ffffff;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="800" width="380" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e_bot_mov_get" value="GetComponent&lt;Movement&gt;()&#10;_movement.isBot = true" style="endArrow=open;html=1;endSize=10;fontSize=11;exitX=0;exitY=0.3;entryX=1;entryY=0.3;" edge="1" parent="1" source="bot" target="mov"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_bot_mov_act" value="SetBotAction(ACT_DOWN / HOLD / UP / NONE)" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=0;exitY=0.55;entryX=1;entryY=0.55;strokeColor=#1b5e20;strokeWidth=2;" edge="1" parent="1" source="bot" target="mov"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_mov_bot_evt" value="event OnDied → HandleDeath()&#10;event OnWon  → HandleWin()" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=1;exitY=0.85;entryX=0;entryY=0.85;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="mov" target="bot"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_bot_rb" value="GetComponent&lt;Rigidbody2D&gt;()&#10;đọc velocity (observation)&#10;reset velocity / gravityScale (episode)" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="bot" target="rb"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_mov_rb" value="dùng Rigidbody2D&#10;(velocity, gravityScale)" style="endArrow=open;html=1;endSize=10;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="mov" target="rb"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_dec_bot" value="RequestDecision()&#10;(mỗi DecisionPeriod)" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=0.5;exitY=0;entryX=0.5;entryY=1;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1" source="dec" target="bot"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_bot_grid" value="khai báo cùng GameObject&#10;ISensor gắn vào Agent" style="endArrow=open;html=1;endSize=10;fontSize=11;dashed=1;exitX=1;exitY=0.2;entryX=0;entryY=0.5;" edge="1" parent="1" source="bot" target="grid"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_grid_sensor" value="CreateSensors()" style="endArrow=open;html=1;endSize=10;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="grid" target="grid_sensor"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_sensor_world" value="OverlapBox per cell&#10;→ phát hiện theo tag" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="grid_sensor" target="grid_world"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_sensor_bot" value="Visual observation (H×W×C)" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1" source="grid_sensor" target="bot"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_bot_brain" value="Vector obs:&#10;y, vx, vy, gamemode, gravity, onGround&#10;+ Visual obs (Grid2DSensor)" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=0.5;exitY=1;entryX=0.4;entryY=0;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="bot" target="brain"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_brain_bot" value="DiscreteAction [0|1]&#10;→ OnActionReceived" style="endArrow=classic;html=1;endSize=10;fontSize=11;exitX=0.6;exitY=0;entryX=0.6;entryY=1;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;" edge="1" parent="1" source="brain" target="bot"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_brain_trainer" value="Inference / Training" style="endArrow=open;html=1;endSize=10;fontSize=11;startArrow=open;exitX=0.5;exitY=1;entryX=0.5;entryY=0;dashed=1;" edge="1" parent="1" source="brain" target="trainer"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="legend" value="Chú thích các luồng:&#10;&#10;━━ Xanh lá : BotControl điều khiển Movement (SetBotAction theo action ML-Agents)&#10;━━ Đỏ (nét đứt) : Movement phát event OnDied / OnWon → BotControl xử lý reward + EndEpisode&#10;━━ Cam : DecisionRequester nhịp gọi RequestDecision() trên Agent&#10;━━ Tím : Grid2DSensor → Visual observation tới Agent&#10;━━ Xanh dương : Observation ↔ Policy (NN) — Action trả về Agent&#10;━━ Đen (nét đứt) : RequireComponent / khai báo cùng GameObject" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#888888;fontSize=11;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="700" width="500" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="loop_t" value="Vòng đời 1 step ML-Agents" style="text;html=1;fontStyle=1;fontSize=13;align=left;" vertex="1" parent="1">
          <mxGeometry x="970" y="700" width="500" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="loop" value="1. DecisionRequester → Agent.RequestDecision()&#10;2. CollectObservations(): đọc Movement + Rigidbody2D&#10;3. Grid2DSensor.Write(): quét OverlapBox theo lưới&#10;4. Policy (.onnx) suy luận → DiscreteAction&#10;5. OnActionReceived(): SetBotAction + AddReward&#10;6. Movement.FixedUpdate(): di chuyển, va chạm,&#10;   nếu chết/đến đích → OnDied / OnWon&#10;7. HandleDeath / HandleWin → EndEpisode()&#10;8. OnEpisodeBegin(): reset spawn, gamemode, vận tốc" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="970" y="720" width="500" height="160" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
