<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram name="Luồng tải level" id="flow-load">
    <mxGraphModel dx="1200" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Luồng tải level (đọc file JSON → dựng lại scene)" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1160" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="Chọn màn / vào màn chơi&#10;(levelFileName được truyền)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="360" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="LevelGenerator.InitLevel(levelFileName)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="160" width="360" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="Đọc file JSON&#10;TextAsset = Resources.Load&lt;TextAsset&gt;(&quot;Level/&quot; + fileName)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="420" y="250" width="360" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="dec" value="JSON tồn tại?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="360" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="err" value="Log error&#10;&quot;Level JSON not found&quot;&#10;→ thoát" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="320" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="Parse JSON&#10;level = JsonUtility.FromJson&lt;LevelInfo&gt;(json.text)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="420" y="480" width="360" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s4" value="Dọn scene cũ&#10;• Destroy mọi child của container&#10;• ObjSelectionButton.ClearPlaced()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="580" width="450" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s5" value="Cập nhật UI metadata (nếu đang trong Editor)&#10;levelName.text  = level.name&#10;startTime.text  = level.startTime&#10;musicText.text  = level.music" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="670" y="580" width="450" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="loop" value="Với mỗi Item trong level.items:" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="1040" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="FindPrefab(item.prefabName)&#10;trong mapPrefabs" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="760" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s7" value="Instantiate(&#10;  prefab,&#10;  position = (item.x, item.y, 0),&#10;  rotation = Quaternion.Euler(0,0,item.zRotate),&#10;  parent = container)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="760" width="380" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="s8" value="ApplyAlpha(item.alpha)&#10;+ RegisterPlaced(obj)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="760" y="760" width="360" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="music" value="LoadMusicFromPersistent(level.music)&#10;Coroutine: UnityWebRequestMultimedia.GetAudioClip(&quot;file://&quot; + path, MPEG)&#10;→ loadedMusic (AudioClip)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="900" width="800" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="endn" value="Scene đã dựng xong — sẵn sàng chơi / preview" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="1030" width="440" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="start" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;" edge="1" parent="1" source="s2" target="dec"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="Không" style="endArrow=classic;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;fontSize=11;" edge="1" parent="1" source="dec" target="err"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="Có" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=11;" edge="1" parent="1" source="dec" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="endArrow=classic;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s3" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="endArrow=classic;html=1;" edge="1" parent="1" source="s4" target="loop"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" style="endArrow=classic;html=1;" edge="1" parent="1" source="s5" target="loop"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="loop" target="s6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1;" edge="1" parent="1" source="s6" target="s7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;" edge="1" parent="1" source="s7" target="s8"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.8;entryY=0;" edge="1" parent="1" source="s8" target="music"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.2;entryY=0;" edge="1" parent="1" source="s6" target="music"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e15" style="endArrow=classic;html=1;" edge="1" parent="1" source="music" target="endn"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
