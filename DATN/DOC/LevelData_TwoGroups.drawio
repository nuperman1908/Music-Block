<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram name="Hai nhóm dữ liệu level" id="two-groups">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Hai nhóm dữ liệu của một level" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1160" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="level" value="LevelInfo (1 level)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;fontStyle=1;" vertex="1" parent="1">
