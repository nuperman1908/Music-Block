        <mxCell id="g1" value="Nhóm 1 — Thông tin chung (Metadata)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="500" height="620" as="geometry"/>
        </mxCell>

        <mxCell id="g1_id" value="id : int&#10;Mã định danh duy nhất của level" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" vertex="1" parent="1">
