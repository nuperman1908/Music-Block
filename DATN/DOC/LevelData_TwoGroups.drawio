        <mxCell id="g2_list" value="items : List&lt;Item&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
