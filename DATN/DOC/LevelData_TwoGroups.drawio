        </mxCell>
        <mxCell id="g1_name" value="name : string&#10;Tên hiển thị do người chơi đặt" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="290" width="460" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="g1_diff" value="difficulty : int&#10;Độ khó (0 = mặc định)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="460" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="g1_music" value="music : string&#10;Tên file nhạc nền (.mp3) đã lưu trong thư mục music/" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="460" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="g1_start" value="startTime : float&#10;Thời điểm (giây) bắt đầu phát nhạc khi vào màn" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="460" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="g1_note" value="Mục đích:&#10;• Hiển thị thông tin level ở menu chọn màn&#10;• Đồng bộ nhạc khi vào chơi / preview&#10;• Định danh khi đặt tên file level_{id}.json" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
