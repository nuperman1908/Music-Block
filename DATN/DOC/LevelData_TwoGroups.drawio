          <mxGeometry x="660" y="495" width="460" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="g2_note" value="Mục đích:&#10;• Lưu toàn bộ vật thể đã đặt trên lưới&#10;• Khi load: lặp qua list → Instantiate prefab theo prefabName,&#10;  đặt tại (x,y), xoay zRotate, áp alpha&#10;• Số lượng phần tử = số object trong scene khi lưu&#10;• Mỗi object trên scene ↔ 1 phần tử Item trong list" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e6f4e1;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
