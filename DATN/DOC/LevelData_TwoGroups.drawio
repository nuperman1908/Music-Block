        </mxCell>

        <mxCell id="i_prefab" value="prefabName : string&#10;Loại vật thể: block / spike / portal / speed / end ..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
