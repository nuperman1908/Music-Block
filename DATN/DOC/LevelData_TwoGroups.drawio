        </mxCell>
        <mxCell id="i_alpha" value="alpha : float&#10;Độ trong suốt sprite (0..1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="430" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="i_grp" value="groupId : int&#10;Mã nhóm (chuyển động / liên kết)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
