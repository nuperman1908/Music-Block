        <mxCell id="e_l_g1" style="endArrow=open;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;endSize=10;fontSize=11;" edge="1" parent="1" source="level" target="g1" value="metadata"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_l_g2" style="endArrow=open;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;endSize=10;fontSize=11;" edge="1" parent="1" source="level" target="g2" value="object list"><mxGeometry relative="1" as="geometry"/></mxCell>

