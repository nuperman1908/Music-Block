<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram name="Luồng lưu level" id="flow-save">
    <mxGraphModel dx="1200" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Luồng lưu level (từ Editor → ghi file JSON)" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1160" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="Người chơi nhấn nút &quot;Lưu&quot; trong Level Editor" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="360" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="LevelEditorManager.SaveLevel()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="160" width="360" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="Thu thập metadata từ UI&#10;levelName.text  →  name&#10;startTime.text  →  startTime (float)&#10;MusicSelector.SelectedPath  →  music" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="450" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="Duyệt container.transform&#10;Với mỗi child trong container:&#10;  • prefabName = StripCloneSuffix(child.name)&#10;  • x = child.position.x ;  y = child.position.y&#10;  • zRotate = child.eulerAngles.z&#10;  • alpha = SpriteRenderer.color.a&#10;  → thêm Item vào level.items" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="670" y="260" width="450" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="s4" value="LevelSerializer.SaveMusicFile(sourcePath)&#10;• Tạo thư mục music/ nếu chưa có&#10;• File.Copy(.mp3) vào persistentDataPath/music/&#10;• Trả về tên file → lưu vào level.music" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="450" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="s5" value="Tạo đối tượng LevelInfo&#10;{ id = |name.GetHashCode()|, name, difficulty=0,&#10;  music, startTime, items[ ] }" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="420" y="540" width="360" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="LevelSerializer.Save(level)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="680" width="360" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="s7" value="JsonUtility.ToJson(level, prettyPrint:true)&#10;→ chuỗi JSON" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="760" width="450" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s8" value="File.WriteAllText(&#10;  persistentDataPath/levels/level_{id}.json,&#10;  json)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacing=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="670" y="760" width="450" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="fs" value="Hệ thống tệp&#10;persistentDataPath/&#10;├── levels/level_{id}.json&#10;└── music/my_song.mp3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1e1e1e;strokeColor=#666666;fontColor=#d4d4d4;fontFamily=Courier New;fontSize=12;align=left;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="890" width="460" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="endn" value="Hoàn tất — màn đã được lưu" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="1030" width="320" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="start" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s1" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;" edge="1" parent="1" source="s2" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.7;entryY=0;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.3;entryY=0;" edge="1" parent="1" source="s3" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;" edge="1" parent="1" source="s5" target="s6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="endArrow=classic;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s6" target="s7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" style="endArrow=classic;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s6" target="s8"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.3;entryY=0;" edge="1" parent="1" source="s7" target="fs"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.7;entryY=0;" edge="1" parent="1" source="s8" target="fs"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;" edge="1" parent="1" source="fs" target="endn"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
